# === Rust / Cargo ===
# Ignore per-crate build outputs (Cargo places these under each crate directory)
target/
.rustc_info.json
**/*.rs.bk

# This repo contains multiple small binary crates; keep lockfiles out of git.
Cargo.lock

# Rust Analyzer / tooling
rust-project.json

# If this is a binary-only project, keep Cargo.lock ignored.
# For libraries, you may want to COMMIT Cargo.lock.

# === IDEs ===
.vscode/
.idea/
*.swp
*.swo

# Editor/CLI tooling caches
.cache/

# === OS files ===
.DS_Store
Thumbs.db

# === Logs ===
*.log

# === Compiled artifacts ===
*.out
*.exe

# === Coverage / profiling ===
*.profraw
*.profdata
